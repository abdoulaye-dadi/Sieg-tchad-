        /* BADGES */
        .badge {
            display: inline-block;
            padding: 5px 12px;
            border-radius: 30px;
            font-size: 11px;
            font-weight: 600;
            background: #e8f5e9;
            color: #1B5E20;
            border: 1px solid #a5d6a7;
