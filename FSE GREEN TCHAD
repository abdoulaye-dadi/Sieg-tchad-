        /* RESET ET STYLES DE BASE */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
        }

        body {
            background: #e8f0e8;
            display: flex;
            justify-content: center;
            min-height: 100vh;
            padding: 0;
        }

        /* CONTENEUR PRINCIPAL (STYLE IPHONE) */
        .app-container {
            max-width: 390px;
            width: 100%;
            background: white;
            min-height: 100vh;
            box-shadow: 0 0 30px rgba(0,40,0,0.15);
            position: relative;
            display: flex;
            flex-direction: column;
            border-radius: 0;
            overflow: hidden;
        }

        /* STATUS BAR */
        .status-bar {
            display: flex;
            justify-content: space-between;
            padding: 12px 20px 6px;
            font-size: 15px;
            font-weight: 600;
            color: #1B5E20;
            background: white;
            border-bottom: 1px solid #d0e8d0;
        }

        /* HEADER AVEC LOGOS */
        .header {
            background: linear-gradient(165deg, #f8fff8, white);
            padding: 20px 15px 20px;
            border-bottom: 3px solid #2E7D32;
        }

        /* Logo FSE Institution */
        .fse-logo {
            text-align: center;
            margin-bottom: 15px;
            padding-bottom: 15px;
            border-bottom: 1px dashed #4CAF50;
        }

        .fse-title {
            font-size: 26px;
            font-weight: 900;
            color: #1B5E20;
            line-height: 1.2;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .fse-subtitle {
            font-size: 16px;
            font-weight: 600;
            color: #2E7D32;
            margin-top: 5px;
        }

        .fse-arabic {
            font-size: 22px;
            color: #2E7D32;
            margin-top: 8px;
            font-family: 'Arial', sans-serif;
        }

        .fse-small {
            font-size: 11px;
            color: #558B2F;
            margin-top: 5px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        /* Logo Green Tchad */
        .green-logo {
            text-align: center;
            margin-top: 10px;
        }

        .green-fse {
            font-size: 40px;
            font-weight: 900;
            color: #1B5E20;
            line-height: 1;
            text-shadow: 1px 1px 0 #c8e6c9;
        }

        .green-tchad {
            font-size: 34px;
            font-weight: 800;
            color: #2E7D32;
            letter-spacing: 3px;
            margin-top: -3px;
        }

        .green-desc {
            font-size: 12px;
            color: #33691E;
            font-weight: 600;
            text-transform: uppercase;
            margin-top: 8px;
            line-height: 1.4;
            max-width: 300px;
            margin-left: auto;
            margin-right: auto;
        }

        /* NAVIGATION PAR ONGLETS */
        .nav-tabs {
            display: flex;
            background: white;
            border-bottom: 1px solid #c8e6c9;
            box-shadow: 0 2px 5px rgba(0,30,0,0.05);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .nav-item {
            flex: 1;
            text-align: center;
            padding: 14px 0 10px;
            font-size: 13px;
            font-weight: 600;
            color: #558B2F;
            cursor: pointer;
            border-bottom: 3px solid transparent;
            transition: all 0.2s;
        }

        .nav-item.active {
            color: #1B5E20;
            border-bottom: 3px solid #2E7D32;
            font-weight: 700;
        }

        /* ZONE DE CONTENU */
        .content {
            flex: 1;
            overflow-y: auto;
            padding: 20px 15px 30px;
            background: #f5faf5;
        }

        /* CARTES */
        .card {
            background: white;
            border-radius: 24px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 5px 15px rgba(0,30,0,0.05);
            border: 1px solid #dcedc8;
