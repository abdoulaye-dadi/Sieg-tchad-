        .badge-warning { background: #fff8e1; color: #bf360c; border-color: #ffb74d; }
        .badge-danger { background: #ffebee; color: #b71c1c; border-color: #ef9a9a; }

        /* BARRE DE PROGRESSION */
        .progress {
            background: #e0e0e0;
            height: 8px;
            border-radius: 20px;
            margin: 12px 0;
            overflow: hidden;
        }

        .progress-fill {
            background: #2E7D32;
            height: 8px;
            border-radius: 20px;
            width: 0%;
        }

        /* BOUTON */
        .btn {
            background: #2E7D32;
            color: white;
            border: none;
            border-radius: 40px;
            padding: 16px;
            font-size: 16px;
            font-weight: 700;
            width: 100%;
            margin-top: 15px;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(46,125,50,0.3);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid #2E7D32;
            color: #2E7D32;
            box-shadow: none;
        }

        /* LISTE PROJETS */
        .project-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 0;
            border-bottom: 1px solid #e0f0e0;
        }

        .project-item:last-child { border-bottom: none; }

        .project-title {
            font-weight: 700;
            color: #1B5E20;
            margin-bottom: 3px;
        }

        .project-meta {
            font-size: 11px;
            color: #558B2F;
        }

        /* GRILLE AGENTS IA */
        .agents-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin: 20px 0;
        }

        .agent-card {
            background: #f1f8e9;
            border-radius: 16px;
            padding: 12px 5px;
            text-align: center;
            cursor: pointer;
        }

        .agent-icon {
            font-size: 24px;
            margin-bottom: 5px;
        }

        .agent-name {
            font-size: 11px;
            font-weight: 700;
            color: #1B5E20;
        }

        /* BULLES DE MESSAGE */
        .message {
            background: #f1f8e9;
            border-radius: 20px 20px 20px 5px;
            padding: 14px;
            margin-bottom: 12px;
            max-width: 85%;
        }

        .message.own {
            background: #2E7D32;
            color: white;
            margin-left: auto;
            border-radius: 20px 20px 5px 20px;
        }

        .message-sender {
            font-size: 11px;
            font-weight: 700;
            margin-bottom: 4px;
            opacity: 0.9;
        }

        .message-time {
            font-size: 9px;
            margin-top: 6px;
            opacity: 0.7;
            text-align: right;
        }

        /* INPUT */
        .input-group {
            display: flex;
            gap: 10px;
            margin-top: 15px;
