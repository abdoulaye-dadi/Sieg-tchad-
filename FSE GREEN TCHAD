        .card-title {
            font-size: 18px;
            font-weight: 700;
            color: #1B5E20;
            margin-bottom: 15px;
            padding-left: 12px;
            border-left: 5px solid #2E7D32;
        }

        /* STATISTIQUES */
        .stats-row {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
        }

        .stat-box {
            flex: 1;
            background: #f1f8e9;
            border-radius: 20px;
            padding: 16px 5px;
            text-align: center;
        }

        .stat-number {
            font-size: 24px;
            font-weight: 800;
            color: #1B5E20;
        }

        .stat-label {
            font-size: 11px;
            color: #33691E;
            font-weight: 600;
            margin-top: 5px;
            text-transform: uppercase;
        }

        /* ALERTES */
        .alert {
            background: #ffebee;
            border-radius: 16px;
            padding: 15px;
            margin-bottom: 12px;
            border-left: 6px solid #d32f2f;
        }

        .alert-title {
            font-weight: 700;
            color: #b71c1c;
            font-size: 16px;
        }

        .alert-loc {
            font-size: 13px;
            color: #c62828;
            margin-top: 5px;
